# Application Settings
APP_NAME="ANPR API"
APP_ENV="development"
LOG_LEVEL="DEBUG"

# Triton Server Configuration
# gRPC port is typically 8001 (HTTP is 8000)
# DO NOT include http:// or https:// prefix for gRPC
# TRITON_SERVER_URL="172.50.32.89:8001"
TRITON_SERVER_URL="127.0.0.1:8001"
TRITON_MODEL_NAME="plate_region_detection_rt_detr"
TRITON_PROTOCOL="grpc"
MODEL_CLASS_NAMES="number_plate"
OCR_CLASS_IDS="0"

# Processing Configuration
BATCH_SIZE=8
INPUT_FOLDER="data/input"
OUTPUT_FOLDER="data/output"
MODELS_DIR="models"

# Detection Settings
CONFIDENCE_THRESHOLD=0.2
IOU_THRESHOLD=0.5
BLUR_THRESHOLD=20.0

# Video Processing
ENABLE_VIDEO_DETECTION=true
FRAMES_PER_SECOND=1.0

# File Extensions
VIDEO_EXTENSIONS=.mp4,.avi,.mov,.mkv,.webm
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.JPG,.JPEG,.PNG

# OCR Configuration
OCR_LANGUAGES=en
X_PADDING=0.20
Y_PADDING=0.20

# InternVL2 OCR (Optional)
USE_INTERNVL2=false
INTERNVL2_MODEL_PATH=OpenGVLab/InternVL2-1B
INTERNVL2_DEVICE=cuda
INTERNVL2_INPUT_SIZE=448

# CEPH/S3 Storage (Optional)
CEPH_ACCESS_KEY=
CEPH_SECRET_ACCESS_KEY=
CEPH_REGION=us-east-1
CEPH_BUCKET_NAME=
CEPH_ENDPOINT_URL=
